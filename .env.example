# Copy this file to .env and fill in your keys.
# Load with: export $(grep -v '^#' .env | xargs)
# Or use python-dotenv / direnv.

# Required — Orchestrator (o3), ServiceFingerprinter (gpt-4o-mini), ValidationAgent
OPENAI_API_KEY=sk-...

# Required — WebReconAgent (Claude Sonnet 4.6)
ANTHROPIC_API_KEY=sk-ant-...

# Required — DNS, Network, Port, Report agents (Gemini Flash / Pro)
GOOGLE_API_KEY=AIza...

# Required — OSINTAgent (Perplexity Sonar Pro)
PERPLEXITY_API_KEY=pplx-...

# Optional — Shodan CLI lookups (shodan host, shodan search)
# SHODAN_API_KEY=...

# Optional — URL for the Go tool runner if not on default port
# RECON_RUNNER_URL=http://127.0.0.1:7373
